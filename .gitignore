# --- Dependencies ---
**/node_modules/
**/bower_components/
**/build/
**/dist/

# --- Environment & Secrets ---
# Crucial: Never commit your .env files containing MySQL passwords
.env
.env.local
.env.*.local
.txt
*.pem
*.key
*.crt

# --- Terraform Specific ---
# Ignore local provider binaries and lock files
.terraform/
.terraform.lock.hcl

# Ignore terraform state files (highly sensitive, contains infra metadata)
*.tfstate
*.tfstate.backup
*.tfstate.lock.info

# Ignore the actual values file (where your IP and keys live)
terraform.tfvars
terraform.tfvars.json
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# --- Docker & Logs ---
**/logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
docker-compose.override.yml

# --- Database Persistence ---
**/mysql_data/
**/db_data/
*.sql
*.sqlite

# --- OS & Editor Specific ---
.DS_Store
.vscode/
.idea/
*.swp

# --- Testing ---
**/coverage/